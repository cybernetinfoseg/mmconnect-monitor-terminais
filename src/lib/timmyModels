export function getSupportedBioTypes(modelo) {
  const cap = getTimmyCapabilities(modelo);
  return ALL_BIO_TYPES.filter(bt => cap.supportedBackupnums.includes(bt.value));
}

/**
 * Para o `setuserinfo` Timmy, escolhe o melhor backupnum com base nos tipos selecionados pelo colaborador.
 * Prioridade: face(15) > face+fp(20) > fp(1-5) > card(11) > pw(10)
 */
export function resolvePrimaryBackupnum(bioTypes = [], user = {}) {
  if (bioTypes.includes(15)) return { backupnum: 15, record: 0 };
  if (bioTypes.includes(20)) return { backupnum: 20, record: 0 };
  if ([1,2,3,4,5].some(v => bioTypes.includes(v))) {
    const fp = [1,2,3,4,5].find(v => bioTypes.includes(v));
    return { backupnum: fp, record: 0 };
  }
  if (bioTypes.includes(11)) return { backupnum: 11, record: Number(user.card) || 0 };
  if (bioTypes.includes(10)) return { backupnum: 10, record: 0 };
  return { backupnum: 10, record: 0 };
}