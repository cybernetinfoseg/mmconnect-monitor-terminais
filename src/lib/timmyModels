  { value: 1,  label: 'FP — Dedo 1',     icon: '🖐️', group: 'fp' },
  { value: 2,  label: 'FP — Dedo 2',     icon: '🖐️', group: 'fp' },
  { value: 3,  label: 'FP — Dedo 3',     icon: '🖐️', group: 'fp' },
