export function getModeInfo(mode, rawMode) {
  // Try numeric rawMode first, then string mode
  const key = rawMode ?? mode;
  return TIMMY_MODE_LABELS[key] || TIMMY_MODE_LABELS[mode] || { label: String(mode || '—'), icon: '?', color: 'bg-slate-100 text-slate-500 border-slate-200' };
}

