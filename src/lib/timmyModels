/**
 * Retorna as capacidades do terminal com base no campo modelo.
 * @param {string} modelo - terminal.modelo
 * @returns {object} capabilities
 */
export function getTimmyCapabilities(modelo) {
  if (!modelo) return GENERIC_CAPABILITIES;
  const m = modelo.toLowerCase().replace(/[-\s]/g, '');
  for (const cap of MODEL_CAPABILITIES) {
    if (cap.match.some(k => m.includes(k.replace(/[-\s]/g, '')))) {
      return cap;
    }
  }
  return GENERIC_CAPABILITIES;
}

/**
 * Dado o modelo do terminal, retorna os tipos biométricos suportados para o formulário de colaborador.
