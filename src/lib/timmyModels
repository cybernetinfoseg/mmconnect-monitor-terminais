  { value: 10, label: 'Senha Numérica',  icon: '🔑', group: 'pw' },
  { value: 11, label: 'Cartão RFID',     icon: '💳', group: 'card' },
  { value: 15, label: 'Face ID',         icon: '😊', group: 'face' },
  { value: 20, label: 'Face + FP',       icon: '🔐', group: 'face_fp' },
