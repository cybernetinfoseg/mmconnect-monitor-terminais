{
  "name": "AgentRegistry",
  "type": "object",
  "properties": {
    "hostname": {
      "type": "string",
      "description": "Hostname da m\u00e1quina onde o agente corre"
    },
    "versao": {
      "type": "string",
      "description": "Vers\u00e3o do agente"
    },
    "tenant_id": {
      "type": "string",
      "description": "ID do Tenant associado"
    },
    "tenant_nome": {
      "type": "string",
      "description": "Nome do tenant (cache)"
    },
    "site_id": {
      "type": "string",
      "description": "ID do Site onde est\u00e1 instalado"
    },
    "site_nome": {
      "type": "string"
    },
    "ip_local": {
      "type": "string"
    },
    "ip_publico": {
      "type": "string"
    },
    "sistema_operativo": {
      "type": "string"
    },
    "terminais_ativos": {
      "type": "number",
      "default": 0,
      "description": "N\u00ba de terminais geridos por este agente"
    },
    "status": {
      "type": "string",
      "enum": [
        "online",
        "offline",
        "degraded",
        "installing"
      ],
      "default": "offline"
    },
    "ultimo_heartbeat": {
      "type": "string",
      "format": "date-time",
      "description": "\u00daltimo heartbeat recebido"
    },
    "primeira_conexao": {
      "type": "string",
      "format": "date-time"
    },
    "configuracao": {
      "type": "string",
      "description": "JSON com configura\u00e7\u00e3o do agente"
    },
    "metricas": {
      "type": "string",
      "description": "JSON com m\u00e9tricas: CPU, RAM, disco"
    },
    "owner_email": {
      "type": "string"
    }
  },
  "required": [
    "hostname"
  ]
}